 # === Java / Maven (backend) ===
  backend/target/
  *.class
  *.jar
  *.war
  *.log
  hs_err_pid*

  # === Node / Vite (frontend) ===
  frontend/node_modules/
  frontend/dist/
  frontend/.vite/
  frontend/*.local
  npm-debug.log*
  yarn-debug.log*
  yarn-error.log*

  # === Python (scripts) ===
  scripts/__pycache__/
  **/__pycache__/
  *.py[cod]
  *$py.class
  .venv/
  venv/
  .python-version

  # === IDEs / Editores ===
  .idea/
  *.iml
  .vscode/*
  !.vscode/settings.json
  !.vscode/extensions.json
  *.swp
  *.swo
  .DS_Store
  Thumbs.db

  # === Variables de entorno / secretos ===
  .env
  .env.local
  .env.*.local
  *.pem
  *.key

  # === Docker ===
  docker/.env

  # === Logs y temporales ===
  *.log
  logs/*.log
  tmp/
  temp/